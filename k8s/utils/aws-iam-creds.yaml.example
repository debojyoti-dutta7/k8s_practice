apiVersion: v1
kind: Secret
metadata:
  name: aws-iam-creds
  namespace: snapee
type: Opaque
data:
  # Base64 encoded values for:
  # AWS_ACCESS_KEY_ID
  # AWS_SECRET_ACCESS_KEY
  # AWS_DEFAULT_REGION (e.g., ap-south-1)
  AWS_ACCESS_KEY_ID: REPLACE_WITH_BASE64_ACCESS_KEY
  AWS_SECRET_ACCESS_KEY: REPLACE_WITH_BASE64_SECRET_KEY
  AWS_DEFAULT_REGION: YXAtc291dGgtMQ== # ap-south-1
